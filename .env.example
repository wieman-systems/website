# Contact form delivery (Resend) — https://resend.com
# Set these in Vercel: Project → Settings → Environment Variables,
# and in a local .env.local for development.

# Required: your Resend API key (starts with "re_").
RESEND_API_KEY=

# Optional overrides (sensible defaults are baked into the API route):
# Where leads are delivered.
CONTACT_TO=caleb@wiemansystems.com
# Sender. Works out of the box with Resend's shared sender. Once you verify
# wiemansystems.com in Resend, switch this to e.g. "Wieman Systems <hello@wiemansystems.com>".
CONTACT_FROM="Wieman Systems <onboarding@resend.dev>"
